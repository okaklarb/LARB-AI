        async function generateFast(messagesForAI, aiContentDiv) {
            abortController = new AbortController();
            aiContentDiv.innerHTML = '<div class="dots"><span></span><span></span><span></span></div> Думаю...';
            
            const response = await fetch("https://text.pollinations.ai/openai", {
                method: "POST", headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ model: "openai-fast", messages: messagesForAI, stream: true, temperature: 0.7 }),
                signal: abortController.signal
            });
            if (!response.ok) throw new Error("Network error");

            const reader = response.body.getReader();
            const decoder = new TextDecoder();
            let buffer = '', fullResponse = '';
            let displayedText = "", printBuffer = "", isTypingStarted = false;
            
            let printInterval = setInterval(() => {
                if (printBuffer.length > 0) {
                    if (!isTypingStarted) { aiContentDiv.innerHTML = ''; isTypingStarted = true; }
                    let charsToPrint = Math.min(printBuffer.length, 2);
                    displayedText += printBuffer.slice(0, charsToPrint);
                    printBuffer = printBuffer.slice(charsToPrint);
                    aiContentDiv.innerHTML = marked.parse(displayedText);
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                }
            }, 15);

            while (true) {
                const { done, value } = await reader.read();
                if (done) break;
                buffer += decoder.decode(value, { stream: true });
                const lines = buffer.split('\n'); buffer = lines.pop();
                for (const line of lines) {
                    if (line.startsWith('data: ') && line.trim() !== 'data: [DONE]') {
                        try {
                            const json = JSON.parse(line.slice(6));
                            const delta = json.choices[0]?.delta?.content || "";
                            if (delta) { fullResponse += delta; printBuffer += delta; }
                        } catch (e) {}
                    }
                }
            }
            await new Promise(r => { let w = setInterval(() => { if (printBuffer.length === 0) { clearInterval(w); r(); } }, 15); });
            clearInterval(printInterval);
            
            aiContentDiv.innerHTML = marked.parse(fullResponse || "Пустой ответ.");
            const footer = document.createElement('div');
            footer.className = 'model-footer'; footer.textContent = `Larb AI v1.0 / fast`;
            aiContentDiv.parentElement.appendChild(footer);
            currentChat.messages.push({ role: "assistant", content: fullResponse });
            saveChatToHistory();
        }

        async function generateThinking(messagesForAI, aiContentDiv) {
            isThinkingPhase = true;
            partialThoughts = "";
            abortController = new AbortController();

            // Показываем блок рассуждения только если кнопка включена
            if (showReasoning) {
                aiContentDiv.innerHTML = `
                    <div class="reasoning-wrapper open">
                        <div class="reasoning-header" onclick="this.closest('.reasoning-wrapper').classList.toggle('open')">
                            <span class="reasoning-toggle">Глубокое размышление <span class="arrow-down">▼</span></span>
                        </div>
                        <div class="reasoning-text"></div>
                    </div>
                    <div class="answer-text"></div>
                `;
            } else {
                aiContentDiv.innerHTML = `<div class="answer-text"></div>`;
            }
            const reasTextDiv = aiContentDiv.querySelector('.reasoning-text');
            const ansTextDiv = aiContentDiv.querySelector('.answer-text');
            ansTextDiv.innerHTML = '<div class="dots"><span></span><span></span><span></span></div> Обдумываю...';
            if (reasTextDiv) reasTextDiv.innerHTML = '<div class="dots"><span></span><span></span><span></span></div> Размышляю...';

            const response = await fetch("https://text.pollinations.ai/openai", {
                method: "POST", headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ model: "openai-fast", messages: messagesForAI, stream: true, temperature: 0.7 }),
                signal: abortController.signal
            });
            if (!response.ok) throw new Error("Network error");

            const reader = response.body.getReader();
            const decoder = new TextDecoder();
            let buffer = '';
            let fullRaw = '';

            // Посимвольный вывод для рассуждений (только если showReasoning включён)
            let reasPrintBuf = '';
            let reasDisplayed = '';
            let reasTypingStarted = false;
            let inThinkStream = false;
            let streamTagBuf = '';

            const reasInterval = setInterval(() => {
                if (showReasoning && reasTextDiv && reasPrintBuf.length > 0) {
                    if (!reasTypingStarted) { reasTextDiv.innerHTML = ''; reasTypingStarted = true; }
                    let take = Math.min(reasPrintBuf.length, 3);
                    reasDisplayed += reasPrintBuf.slice(0, take);
                    reasPrintBuf = reasPrintBuf.slice(take);
                    partialThoughts = reasDisplayed;
                    reasTextDiv.innerHTML = marked.parse(reasDisplayed);
                    chatMessages.scrollTop = chatMessages.scrollHeight;
                } else if (!showReasoning) {
                    // Просто очищаем буфер без отображения
                    reasPrintBuf = '';
                }
            }, 15);

            const thinkStartTime = Date.now();
            const MIN_THINK_MS = 10000; // минимум 10 секунд на обдумывание

            try {
                while (true) {
                    const { done, value } = await reader.read();
                    if (done) break;
                    buffer += decoder.decode(value, { stream: true });
                    const lines = buffer.split('\n'); buffer = lines.pop();
                    for (const line of lines) {
                        if (line.startsWith('data: ') && line.trim() !== 'data: [DONE]') {
                            try {
                                const json = JSON.parse(line.slice(6));
                                const delta = json.choices[0]?.delta;
                                if (!delta || !delta.content) continue;
                                fullRaw += delta.content;

                                // Стримовый парсинг для посимвольного вывода рассуждений
                                streamTagBuf += delta.content;
                                while (streamTagBuf.length > 0) {
                                    if (inThinkStream) {
                                        const closeIdx = streamTagBuf.indexOf('</think>');
                                        if (closeIdx !== -1) {
                                            reasPrintBuf += streamTagBuf.slice(0, closeIdx);
                                            streamTagBuf = streamTagBuf.slice(closeIdx + 8);
                                            inThinkStream = false;
                                        } else {
                                            const TAIL = 8;
                                            if (streamTagBuf.length > TAIL) {
                                                reasPrintBuf += streamTagBuf.slice(0, streamTagBuf.length - TAIL);
                                                streamTagBuf = streamTagBuf.slice(streamTagBuf.length - TAIL);
                                            }
                                            break;
                                        }
                                    } else {
                                        const openIdx = streamTagBuf.indexOf('<think>');
                                        if (openIdx !== -1) {
                                            streamTagBuf = streamTagBuf.slice(openIdx + 7);
                                            inThinkStream = true;
                                        } else {
                                            const TAIL = 7;
                                            if (streamTagBuf.length > TAIL) streamTagBuf = streamTagBuf.slice(streamTagBuf.length - TAIL);
                                            break;
                                        }
                                    }
                                }
                            } catch (e) {}
                        }
                    }
                }

                // Гарантируем минимум 10 секунд обдумывания
                const elapsed = Date.now() - thinkStartTime;
                if (elapsed < MIN_THINK_MS) {
                    await new Promise(r => setTimeout(r, MIN_THINK_MS - elapsed));
                }

                // Ждём пока буфер рассуждений допечатается
                await new Promise(r => { let w = setInterval(() => { if (reasPrintBuf.length === 0) { clearInterval(w); r(); } }, 15); });
                clearInterval(reasInterval);

                // Финальный чистый разбор
                const thinkOpen = fullRaw.indexOf('<think>');
                const thinkClose = fullRaw.indexOf('</think>');

                let reasoning = '';
                let answer = '';

                if (thinkOpen !== -1 && thinkClose !== -1 && thinkClose > thinkOpen) {
                    reasoning = fullRaw.slice(thinkOpen + 7, thinkClose).trim();
                    answer = fullRaw.slice(thinkClose + 8).trim();
                } else if (thinkOpen !== -1 && thinkClose === -1) {
                    // Тег открыт но не закрыт — всё рассуждение, ответа нет
                    reasoning = fullRaw.slice(thinkOpen + 7).trim();
                    answer = fullRaw.slice(0, thinkOpen).trim();
                } else {
                    // Тегов нет — весь текст ответ, убираем мусор
                    reasoning = '';
                    answer = fullRaw.replace(/<\/?think>/g, '').trim();
                }
                // Дополнительная чистка: убираем любые think-теги из ответа
                answer = answer.replace(/<think>[\s\S]*?<\/think>/g, '').replace(/<\/?think>/g, '').trim();

                if (isThinkingPhase) isThinkingPhase = false;

                if (showReasoning) {
                    const reasoningWrap = aiContentDiv.querySelector('.reasoning-wrapper');
                    if (!reasoning && reasoningWrap) {
                        reasoningWrap.style.display = 'none';
                    } else if (reasoning && reasTextDiv) {
                        reasTextDiv.innerHTML = marked.parse(reasoning);
                        partialThoughts = reasoning;
                    }
                    const toggle2 = aiContentDiv.querySelector('.reasoning-toggle');
                    if (toggle2) toggle2.innerHTML = 'Глубокое размышление ✓ <span class="arrow-down">▼</span>';
                }

                const cleanResponse = answer || "Модель не сформировала ответ. Попробуйте ещё раз.";

                // Посимвольная анимация ответа
                ansTextDiv.innerHTML = '';
                let ansDisplayed = '';
                let ansPrintBuf = cleanResponse;
                await new Promise(r => {
                    const ansInterval = setInterval(() => {
                        if (ansPrintBuf.length > 0) {
                            let take = Math.min(ansPrintBuf.length, 3);
                            ansDisplayed += ansPrintBuf.slice(0, take);
                            ansPrintBuf = ansPrintBuf.slice(take);
                            ansTextDiv.innerHTML = marked.parse(ansDisplayed);
                            chatMessages.scrollTop = chatMessages.scrollHeight;
                        } else {
                            clearInterval(ansInterval);
                            r();
                        }
                    }, 15);
                });

                const footer = document.createElement('div');
                footer.className = 'model-footer'; footer.textContent = `Larb AI v1.0 / thinking`;
                aiContentDiv.parentElement.appendChild(footer);
                currentChat.messages.push({ role: "assistant", content: cleanResponse });
                saveChatToHistory();

            } catch (err) {
                clearInterval(reasInterval);
                throw err;
            }
        }

        async function generateAnswer(messagesForAI, aiContentDiv) {
            abortController = new AbortController();
            
            const stopBtn = aiContentDiv.querySelector('.stop-reasoning-btn');
            if (stopBtn) stopBtn.style.display = 'none';
            const toggle = aiContentDiv.querySelector('.reasoning-toggle');
            if (toggle) toggle.innerHTML = 'Глубокое размышление (остановлено) <span class="arrow-down">▼</span>';
            
