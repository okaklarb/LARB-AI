            try {
                const systemPrompt = currentChat.type === 'project' 
                    ? savedProjects.find(p => p.id === currentChat.projectId)?.desc 
                    : (currentModel === 'thinking' ? SYSTEM_THINK : SYSTEM_FAST);

                // Собираем текст для ИИ "на лету", добавляя содержимое файлов
                messagesForAI = [
                    { role: "system", content: systemPrompt }, 
                    ...currentChat.messages.map(m => {
                        let apiContent = m.content || "";
                        if (m.attachments && m.attachments.length > 0) {
                            m.attachments.forEach(att => {
                                apiContent += `\n\n[Содержимое файла ${att.name}]:\n${att.content}`;
                            });
                        }
                        return { role: m.role, content: apiContent };
                    })
                ];

                if (currentModel === 'thinking') {
                    await generateThinking(messagesForAI, aiContentDiv);
                } else {
                    await generateFast(messagesForAI, aiContentDiv);
                }
            } catch (error) {
                if (error.name === 'AbortError' && forceAnswerFlag) {
                    forceAnswerFlag = false;
                    try {
                        await generateAnswer(messagesForAI, aiContentDiv);
                    } catch (e) {
                        aiContentDiv.innerHTML = marked.parse("Ошибка генерации ответа.");
                    }
                } else if (error.name === 'AbortError') {
                    aiContentDiv.innerHTML += '<br><br><i style="color:var(--text-muted)">[Генерация остановлена]</i>';
                } else {
                    aiContentDiv.innerHTML = marked.parse("Ошибка сети. Попробуйте еще раз.");
                }
            } finally {
                isGenerating = false;
                toggleStopButton(false);
