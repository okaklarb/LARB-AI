            }

            // Сохраняем в историю объектом, а не склеенной строкой
            const userMessageObj = { role: "user", content: text, attachments: attachments };
            currentChat.messages.push(userMessageObj);
            
            renderMessage('user', text, attachments);
            userInput.value = '';
            
            isGenerating = true;
            toggleStopButton(true);
            const aiContentDiv = createAIMessageBubble();

            // Объявляем messagesForAI снаружи try, чтобы catch мог его использовать
