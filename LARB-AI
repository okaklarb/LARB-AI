        // Обновленная функция рендера, поддерживающая файлы
        function renderMessage(role, text, attachments = []) {
            const msgDiv = document.createElement('div');
            msgDiv.className = `message ${role}`;
            
            let attachmentsHtml = '';
            if (attachments && attachments.length > 0) {
                attachmentsHtml = attachments.map(att => `
                    <div class="message-attachment">
                        <svg viewBox="0 0 24 24"><path d="M16.5 6v11.5c0 2.21-1.79 4-4 4s-4-1.79-4-4V5c0-1.38 1.12-2.5 2.5-2.5s2.5 1.12 2.5 2.5v10.5c0 .55-.45 1-1 1s-1-.45-1-1V6H10v9.5c0 1.38 1.12 2.5 2.5 2.5s2.5-1.12 2.5-2.5V5c0-2.21-1.79-4-4-4S7 2.79 7 5v12.5c0 3.04 2.46 5.5 5.5 5.5s5.5-2.46 5.5-5.5V6h-1.5z"/></svg>
                        ${att.name}
                    </div>
                `).join('');
            }
            
            msgDiv.innerHTML = `<div class="content">${attachmentsHtml}${marked.parse(text || "")}</div>`;
            if (role === 'ai') {
                const footer = document.createElement('div');
                footer.className = 'model-footer';
                footer.textContent = `Larb AI v1.0 / ${currentModel}`;
                msgDiv.appendChild(footer);
            }
            chatMessages.appendChild(msgDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }

        function saveChatToHistory() {
            const idx = savedChats.findIndex(c => c.id === currentChat.id);
            if (idx === -1) savedChats.push({...currentChat});
            else savedChats[idx] = {...currentChat};
            renderHistory();
            saveChatToCloud(currentChat);
        }

        function renderHistory() {
            const list = document.getElementById('historyList');
            list.innerHTML = '';
            if (savedChats.filter(c => c.type === 'chat').length === 0) { list.innerHTML = '<p style="color:var(--text-muted); font-size:0.8rem;">Пусто</p>'; return; }
            savedChats.filter(c => c.type === 'chat').reverse().forEach(c => {
                const item = document.createElement('div');
                item.className = 'list-item';
                const date = new Date(c.id);
                item.innerHTML = `<h4>${c.title}</h4><p>${date.toLocaleDateString()} • ${c.messages.length} сообщ.</p>`;
                item.onclick = () => loadChat(c.id);
                list.appendChild(item);
            });
        }

        function renderProjects() {
            const list = document.getElementById('projectsList');
            list.innerHTML = '';
            if (savedProjects.length === 0) { list.innerHTML = '<p style="color:var(--text-muted); font-size:0.8rem;">Создайте проект</p>'; return; }
            savedProjects.reverse().forEach(p => {
                const item = document.createElement('div');
                item.className = 'list-item';
                item.innerHTML = `<h4>${p.name}</h4><p>${p.desc.slice(0, 30)}...</p>`;
                item.onclick = () => loadProject(p.id);
                list.appendChild(item);
            });
        }

        function loadChat(id) {
            const chat = savedChats.find(c => c.id === id); if (!chat) return;
            currentChat = JSON.parse(JSON.stringify(chat));
            chatMessages.innerHTML = '';
            // Передаем вложения в рендер
            currentChat.messages.forEach(m => renderMessage(m.role, m.content, m.attachments || []));
            document.getElementById('headerTitle').textContent = "LARB AI";
            closeSidePanel();
        }

        function loadProject(id) {
            const p = savedProjects.find(p => p.id === id); if (!p) return;
            let chat = savedChats.find(c => c.projectId === id);
            if (!chat) { chat = { id: Date.now(), title: p.name, messages: [], type: 'project', projectId: id }; savedChats.push(chat); }
            currentChat = JSON.parse(JSON.stringify(chat));
            chatMessages.innerHTML = '';
            currentChat.messages.forEach(m => renderMessage(m.role, m.content, m.attachments || []));
            document.getElementById('headerTitle').textContent = p.name;
            closeSidePanel();
        }

        renderProjects(); renderHistory();
    </script>
</body>
</html>
